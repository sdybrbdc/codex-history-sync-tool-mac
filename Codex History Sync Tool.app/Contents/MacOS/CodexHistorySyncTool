#!/bin/zsh
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
APP_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
TOOL_ROOT="$(cd "$APP_ROOT/../.." && pwd)"

cd "$TOOL_ROOT"
if [[ "${1:-}" == "--smoke-test" ]]; then
  exec python3 "$TOOL_ROOT/launch_ui_mac.py" --smoke-test
fi

exec python3 "$TOOL_ROOT/launch_ui_mac.py"
